# ══════════════════════════════════════════════════════════════════════════
# STEAMI Network — Backend Environment Variables
# Copy this file to `.env` and fill in real values. Never commit the real
# `.env` file — only this `.env.example` template belongs in git.
# ══════════════════════════════════════════════════════════════════════════

# ── Flask ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
FLASK_DEBUG=false
PORT=8000
OLLAMA_API_KEY=
OLLAMA_MODEL=

# ── Firebase Web API (from your Firebase console → Project Settings → Web App) ──
# No serviceAccountKey.json needed — uses REST API with web key
FIREBASE_API_KEY=
FIREBASE_PROJECT_ID=

# ── Gemini ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=

# ── OpenRouter (optional, not used by default) ──────────────────────────────
OPENROUTER_API_KEY=

# ── JWT Auth ───────────────────────────────────────────────────────────────
# Change this to a long random string in production!
JWT_SECRET=change-me-to-a-long-random-string
TOKEN_EXPIRY_SECONDS=604800

# ── MongoDB Atlas ──────────────────────────────────────────────────────────
# Replace <db_password> with your actual MongoDB Atlas password.
# The database name (steami) is created automatically on first write.
MONGODB_URI=
MONGODB_DB_NAME=steami

# ── DDoS / rate limiting (ddos_protection.py) ───────────────────────────────
RATE_LIMIT_GLOBAL=120
RATE_LIMIT_AUTH=10
RATE_LIMIT_EXPENSIVE=20
RATE_LIMIT_WINDOW=60
MAX_REQUEST_BODY_MB=10
MAX_TEMP_BAN_MINUTES=15
MAX_429_BEFORE_BAN=20
BANNED_IPS=

# ── SMTP (legacy — MailRelay/Brevo below are what's actually used) ─────────
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=
SITE_URL=https://steami.com
SITE_NAME=STEAMI

BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=
API_BASE_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── MailRelay ────────────────────────────────────────────────────────────
MAILRELAY_API_KEY=
MAILRELAY_ACCOUNT=
MAILRELAY_SENDER_EMAIL=hello@steami.com
MAILRELAY_SENDER_NAME=STEAMI Newsletter

# ── Celery / Redis (celery_app.py — daily newsletter beat schedule) ────────
REDIS_URL=redis://localhost:6379/0

# ══════════════════════════════════════════════════════════════════════════
# NEW — Recommendation #8: Weak Email Validation & Spam Account Creation
# (ddos_protection.py, auth_router.py, google_auth.py)
# ══════════════════════════════════════════════════════════════════════════

# ── CAPTCHA (Google reCAPTCHA v2/v3) ────────────────────────────────────────
# If left blank, verify_captcha() always returns True — CAPTCHA enforcement
# is a no-op in local/dev until you set this in production.
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5

# ── Disposable/throwaway email blocklist ────────────────────────────────────
# Comma-separated list of EXTRA domains to block, on top of the built-in
# list already hardcoded in ddos_protection.py (mailinator.com, guerrillamail.com, etc).
DISPOSABLE_EMAIL_DOMAINS=

# ── OAuth: Microsoft (Azure AD) ──────────────────────────────────────────
# Register an app at https://portal.azure.com → App registrations.
# Redirect URI must exactly match what you register there and what the
# frontend uses to build the authorize URL (VITE_MICROSOFT_REDIRECT_URI).
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://yourdomain.com/auth/callback/microsoft

# ── OAuth: GitHub ────────────────────────────────────────────────────────
# Register an OAuth App at https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── OAuth: LinkedIn (OpenID Connect) ────────────────────────────────────
# Register an app at https://www.linkedin.com/developers/apps
# Request the "Sign In with LinkedIn using OpenID Connect" product.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=https://yourdomain.com/auth/callback/linkedin

# ── OAuth: Google (already implemented — routers/google_auth.py) ───────────
# No backend secret needed; the frontend's ID token is verified directly
# against Google's tokeninfo endpoint. Only the frontend needs a client ID
# (see frontend .env.example → VITE_GOOGLE_CLIENT_ID).
